<Window x:Class="BusinessAccountantService.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:local="clr-namespace:BusinessAccountantService.Managers" 
        Title="ВелоСервис CRM" Height="700" Width="1100" 
        WindowStartupLocation="CenterScreen" Background="#F5F5F5">
    <Window.Resources>
        <local:StatusColorConverter x:Key="StatusColorConverter"/>
    </Window.Resources>

    <Grid>
        <!-- Разметка: колонка для меню (200px) и колонка для контента -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Боковая панель меню -->
        <StackPanel Grid.Column="0" Background="#2C3E50">
            <TextBlock Text="BIKE SERVICE" Foreground="White" FontSize="20" 
               FontWeight="Bold" Margin="20" HorizontalAlignment="Center"/>

            <Button Name="BtnAllClients" Content="Все" Height="40" Margin="10,5" Background="#34495E" Foreground="White" BorderThickness="0" Click="ShowAllClients_Click"/>
            <Button Name="BtnActiveOrders" Content="В работе" Height="40" Margin="10,5" Background="#34495E" Foreground="White" BorderThickness="0" Click="ShowActiveOrders_Click"/>
            <Button Name="BtnArchive" Content="В архиве" Height="40" Margin="10,5" Background="#34495E" Foreground="White" BorderThickness="0" Click="ShowArchive_Click"/>

            <Separator Margin="10" Background="#7F8C8D"/>

            <!-- БЛОК СТАТИСТИКИ -->
            <TextBlock Text="ПЕРИОД СТАТИСТИКИ:" Foreground="#7F8C8D" FontSize="10" Margin="15,10,0,0" FontWeight="Bold"/>
            <DatePicker x:Name="StatsDatePicker" Margin="10,2,10,5" Height="30" 
                        CalendarOpened="StatsDatePicker_CalendarOpened"
                        SelectedDateChanged="StatsDatePicker_SelectedDateChanged"
                VerticalContentAlignment="Center" BorderThickness="0"/>

            <Button Content="Итоги месяца" Click="ShowMonthlyStats_Click" 
            Background="#8E44AD" Foreground="White" Height="40" Margin="10,0,10,5" BorderThickness="0"/>

            <!-- Кнопка сброса в самый низ через большой отступ или просто в конце -->
            <Separator Margin="10" Background="#7F8C8D"/>
            <Button Content="СБРОС БАЗЫ (TEST)" Click="ResetDb_Click" 
            Background="#C0392B" Foreground="White" Height ="30" Margin="10,5"/>
        </StackPanel>

        <!-- Основная область -->
        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Поиск и заголовок -->
                <RowDefinition Height="*"/>
                <!-- Таблица КЛИЕНТОВ (верхняя) -->
                <RowDefinition Height="5"/>
                <!-- Разделитель -->
                <RowDefinition Height="*"/>
                <!-- Таблица РЕМОНТОВ (нижняя) -->
                <RowDefinition Height="Auto"/>
                <!-- Кнопки -->
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                <TextBlock Text="Список клиентов" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>

                <Label Content="Поиск:" Margin="30,0,5,0" VerticalAlignment="Center" Foreground="Gray"/>
                <TextBox x:Name="SearchBox" Width="300" Height="28" 
                 VerticalContentAlignment="Center" 
                 TextChanged="SearchBox_TextChanged" />

                <TextBlock x:Name="StatusInfoText" 
               Text="Клиентов: 0 | Заказов: 0" 
               Foreground="#27AE60" 
               FontWeight="Bold" 
               VerticalAlignment="Center" 
               Margin="20,0,0,0"/>
            </StackPanel>
            
            <!-- 1. Таблица КЛИЕНТОВ (называем её ClientsGrid) -->
            <DataGrid x:Name="ClientsGrid" Grid.Row="1" 
                      MouseDoubleClick="ClientsGrid_MouseDoubleClick"
              AutoGenerateColumns="False" SelectionChanged="ClientsGrid_SelectionChanged" CanUserAddRows="False" CanUserDeleteRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40"/>
                    <DataGridTextColumn Header="ФИО Клиента" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="150"/>
                    <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Разделитель (позволяет тянуть вверх-вниз) -->
            <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" Background="#DDDDDD"/>

            <!-- 2. Таблица РЕМОНТОВ (называем её RepairsHistoryGrid) -->
            <StackPanel Grid.Row="3" Margin="0,0,0,0">
                <TextBlock Text="История ремонтов выбранного клиента:" FontWeight="Bold" Margin="0,0,0,5"/>

                <DataGrid x:Name="RepairsHistoryGrid" Height="200"
                          MouseDoubleClick="RepairsHistoryGrid_MouseDoubleClick"
                          CellEditEnding="RepairsHistoryGrid_CellEditEnding"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Статус: Принят" Click="ChangeStatus_Click" Tag="Принят"/>
                            <MenuItem Header="Статус: В работе" Click="ChangeStatus_Click" Tag="В работе"/>
                            <MenuItem Header="Статус: Готов" Click="ChangeStatus_Click" Tag="Готов"/>
                            <Separator/>
                            <MenuItem Header="Статус: Выдан" Click="ChangeStatus_Click" Tag="Выдан" Foreground="DarkGreen" FontWeight="Bold"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Велосипед" Binding="{Binding BikeInfo}" Width="150" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Описание проблемы" Binding="{Binding ProblemDescription}" Width="*" IsReadOnly="True"/>
                        <DataGridComboBoxColumn Header="Статус" Width="120"
                        SelectedItemBinding="{Binding Status, UpdateSourceTrigger=PropertyChanged}">

                            <DataGridComboBoxColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Background" Value="{Binding Status, Converter={StaticResource StatusColorConverter}}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{Binding Status, Converter={StaticResource StatusColorConverter}}"/>
                                            <Setter Property="Foreground" Value="Black"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridComboBoxColumn.CellStyle>

                            <DataGridComboBoxColumn.ElementStyle>
                                <Style TargetType="ComboBox">
                                    <Setter Property="ItemsSource">
                                        <Setter.Value>
                                            <x:Array Type="sys:String" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                                <sys:String>Принят</sys:String>
                                                <sys:String>В работе</sys:String>
                                                <sys:String>Готов</sys:String>
                                                <sys:String>Выдан</sys:String>
                                            </x:Array>
                                        </Setter.Value>
                                    </Setter>
                                    <!-- Делаем комбобокс прозрачным, чтобы видеть цвет ячейки под ним -->
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGridComboBoxColumn.ElementStyle>

                            <DataGridComboBoxColumn.EditingElementStyle>
                                <Style TargetType="ComboBox">
                                    <Setter Property="ItemsSource">
                                        <Setter.Value>
                                            <x:Array Type="sys:String" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                                <sys:String>Принят</sys:String>
                                                <sys:String>В работе</sys:String>
                                                <sys:String>Готов</sys:String>
                                                <sys:String>Выдан</sys:String>
                                            </x:Array>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGridComboBoxColumn.EditingElementStyle>
                        </DataGridComboBoxColumn>
                        <DataGridTextColumn Header="Оплата" Binding="{Binding TotalCost}" Width="80" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Дата приёмки" Binding="{Binding DateFormatted}" Width="110" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>

            <!-- Кнопки действий -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Создать акт приемки (PDF)" Click="EntryAct_Click" Width="155" Height="40" Margin="5" Background="#27AE60" Foreground="White" BorderThickness="0"/>
                <Button Content="Создать акт выдачи (PDF)" Click="FinalAct_Click" Width="150" Height="40" Margin="5" Background="#27AE60" Foreground="White" BorderThickness="0"/>
            </StackPanel>
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,20,0,0">

                <Button Content="Добавить клиента" Click="AddClient_Click" Width="120" Height="30" Margin="5"/>
                <Button Content="Новый заказ" Click="AddRepair_Click" Width="120" Height="30" Margin="5"/>
                
            </StackPanel>

        </Grid>

    </Grid>
</Window>
