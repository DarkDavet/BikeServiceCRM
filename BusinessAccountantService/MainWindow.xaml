<Window x:Class="BusinessAccountantService.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="ВелоСервис CRM" Height="600" Width="1000" 
        WindowStartupLocation="CenterScreen" Background="#F5F5F5">

    <Grid>
        <!-- Разметка: колонка для меню (200px) и колонка для контента -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Боковая панель меню -->
        <StackPanel Grid.Column="0" Background="#2C3E50">
            <TextBlock Text="BIKE SERVICE" Foreground="White" FontSize="20" 
                       FontWeight="Bold" Margin="20" HorizontalAlignment="Center"/>

            <Button Content="Клиенты" Height="40" Margin="10,5" Background="#34495E" Foreground="White" BorderThickness="0"/>
            <Button Content="Велосипеды" Height="40" Margin="10,5" Background="#34495E" Foreground="White" BorderThickness="0"/>
            <Button Content="Заказы в работе" Height="40" Margin="10,5" Background="#34495E" Foreground="White" BorderThickness="0"/>
            <Separator Margin="10" Background="#7F8C8D"/>
            <Button Content="Создать PDF отчет" Height="40" Margin="10,5" Background="#27AE60" Foreground="White" BorderThickness="0"/>
        </StackPanel>

        <!-- Основная область -->
        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Поиск и заголовок -->
                <RowDefinition Height="*"/>
                <!-- Таблица КЛИЕНТОВ (верхняя) -->
                <RowDefinition Height="5"/>
                <!-- Разделитель -->
                <RowDefinition Height="*"/>
                <!-- Таблица РЕМОНТОВ (нижняя) -->
                <RowDefinition Height="Auto"/>
                <!-- Кнопки -->
            </Grid.RowDefinitions>

            <!-- 1. Таблица КЛИЕНТОВ (называем её ClientsGrid) -->
            <DataGrid x:Name="ClientsGrid" Grid.Row="1" 
              AutoGenerateColumns="False" SelectionChanged="ClientsGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40"/>
                    <DataGridTextColumn Header="ФИО Клиента" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Разделитель (позволяет тянуть вверх-вниз) -->
            <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" Background="#DDDDDD"/>

            <!-- 2. Таблица РЕМОНТОВ (называем её RepairsHistoryGrid) -->
            <StackPanel Grid.Row="3" Margin="0,10,0,0">
                <TextBlock Text="История ремонтов выбранного клиента:" FontWeight="Bold" Margin="0,0,0,5"/>
                <DataGrid x:Name="RepairsHistoryGrid" Height="200"
                  AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Велосипед" Binding="{Binding BikeInfo}" Width="150"/>
                        <DataGridTextColumn Header="Проблема" Binding="{Binding ProblemDescription}" Width="*"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding IsCompleted}" Width="80"/>
                        <DataGridTextColumn Header="Сумма" Binding="{Binding TotalCost}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>

            <!-- Кнопки действий -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Добавить клиента" Click="AddClient_Click" Width="120" Height="30" Margin="5"/>
                <Button Content="Новый заказ" Click="AddRepair_Click" Width="120" Height="30" Margin="5"/>
                <Button Content="Акт приемки" Click="EntryAct_Click" Width="120" Height="30" Margin="5"/>
                <Button Content="Выдать чек" Click="FinalAct_Click" Width="120" Height="30" Margin="5"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
