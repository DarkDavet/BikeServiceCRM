<Window x:Class="BusinessAccountantService.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:local="clr-namespace:BusinessAccountantService.Managers" 
        Icon="bl_icon.ico" 
        Title="BikeLab CRM" Height="750" Width="1200" 
        WindowStartupLocation="CenterScreen" Background="#F5F6FA">

    <Window.Resources>
        <local:StatusColorConverter x:Key="StatusColorConverter"/>

        <!-- Общий стиль для кнопок меню -->
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#DCDDE1"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="10,2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0,0,0"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <!-- 1. Когда навели мышкой -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#27AE60"/>
                    <Setter Property="Foreground" Value="#2C3E50"/>
                    <!-- ТЕМНЫЙ ТЕКСТ -->
                </Trigger>

                <!-- 2. КОГДА КНОПКА ВЫБРАНА (Проверка цвета из C#) -->
                <Trigger Property="Background" Value="{x:Static Brushes.LightGreen}">
                    <Setter Property="Foreground" Value="#2C3E50"/>
                    <!-- ТЕМНЫЙ ТЕКСТ -->
                    <Setter Property="FontWeight" Value="Bold"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ЛЕВАЯ ПАНЕЛЬ -->
        <Grid Grid.Column="0" Background="#2C3E50">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Логотип -->
                <RowDefinition Height="*"/>
                <!-- Меню -->
                <RowDefinition Height="Auto"/>
                <!-- Склад и Аналитика -->
            </Grid.RowDefinitions>

            <!-- 1. БЛОК ЛОГОТИПА -->
            <StackPanel Grid.Row="0" Margin="0,30,0,30">
                <!-- Сюда подставится твой BikeLab_logo.png -->
                <Image Source="/BikeLab_logo _1.png" Height="80" Stretch="Uniform" Margin="10"/>
                <TextBlock Text="SERVICE CRM" Foreground="#7F8C8D" FontSize="14" 
                           HorizontalAlignment="Center" Margin="0,-5,0,0"/>
            </StackPanel>

            <!-- 2. ОСНОВНОЕ МЕНЮ -->
            <StackPanel Grid.Row="1">

                <Button Name="BtnAllClients" Content="👥 Все клиенты" Style="{StaticResource MenuButtonStyle}" Click="ShowAllClients_Click"/>
                <Button Name="BtnActiveOrders" Content="🔧 Заказы в работе" Style="{StaticResource MenuButtonStyle}" Click="ShowActiveOrders_Click"/>
                <Button Name="BtnArchive" Content="📁 Архив выдачи" Style="{StaticResource MenuButtonStyle}" Click="ShowArchive_Click"/>
            </StackPanel>

            <!-- 3. НИЖНИЙ БЛОК (СКЛАД И АНАЛИТИКА) -->
            <StackPanel Grid.Row="2" Margin="0,0,0,20">
                <Separator Margin="20,10" Background="#34495E"/>

                <Button Content="📊 Финансовая аналитика" Click="ShowMonthlyStats_Click" 
                        Height="45" Margin="15,5" Background="#8E44AD" Foreground="White" 
                        FontWeight="Bold" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Name="BtnInventory" Content="📦 СКЛАД" Click="ShowInventory_Click" 
                        Height="50" Margin="15,5" Background="#2BA5C0" Foreground="White" 
                        FontWeight="Black" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>

        <!-- КОНТЕНТ (ПРАВАЯ ЧАСТЬ) -->
        <Border Grid.Column="1" Background="White" CornerRadius="15,0,0,15">
            <Grid>
                <!-- Тень удалена для исключения ошибки, добавлена тонкая рамка слева -->
                <Border BorderBrush="#DCDDE1" BorderThickness="1,0,0,0" CornerRadius="15,0,0,15">
                    <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" Margin="5"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
