<Window x:Class="BusinessAccountantService.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="ВелоСервис CRM" Height="600" Width="1000" 
        WindowStartupLocation="CenterScreen" Background="#F5F5F5">

    <Grid>
        <!-- Разметка: колонка для меню (200px) и колонка для контента -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Боковая панель меню -->
        <StackPanel Grid.Column="0" Background="#2C3E50">
            <TextBlock Text="BIKE SERVICE" Foreground="White" FontSize="20" 
                       FontWeight="Bold" Margin="20" HorizontalAlignment="Center"/>

            <Button Content="Клиенты" Height="40" Margin="10,5" Background="#34495E" Foreground="White" BorderThickness="0"/>
            <Button Content="Велосипеды" Height="40" Margin="10,5" Background="#34495E" Foreground="White" BorderThickness="0"/>
            <Button Content="Заказы в работе" Height="40" Margin="10,5" Background="#34495E" Foreground="White" BorderThickness="0"/>
            <Separator Margin="10" Background="#7F8C8D"/>
            <Button Content="Создать PDF отчет" Height="40" Margin="10,5" Background="#27AE60" Foreground="White" BorderThickness="0"/>
        </StackPanel>

        <!-- Основная область -->
        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Заголовок и поиск -->
                <RowDefinition Height="*"/>
                <!-- Таблица -->
                <RowDefinition Height="Auto"/>
                <!-- Кнопки действий -->
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="Список заказов" FontSize="24" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBox Width="250" Margin="30,0,0,0" VerticalAlignment="Center" ToolTip="Поиск..."/>
            </StackPanel>

            <!-- Таблица данных -->
            <DataGrid x:Name="RepairsGrid" Grid.Row="1" 
                      AutoGenerateColumns="False" CanUserAddRows="False"
                      Background="White" BorderBrush="#DDDDDD" RowHeight="30">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Клиент" Binding="{Binding ClientName}" Width="*"/>
                    <DataGridTextColumn Header="Велосипед" Binding="{Binding BikeModel}" Width="*"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                    <DataGridTextColumn Header="Цена" Binding="{Binding Cost}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Кнопки управления снизу -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Добавить заказ" Width="150" Height="35" Background="#2980B9" Foreground="White" Click="AddClient_Click"/>
                <Button Content="Удалить" Width="100" Height="35" Margin="10,0,0,0" Background="#C0392B" Foreground="White"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
