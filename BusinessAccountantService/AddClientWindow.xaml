<Window x:Class="BusinessAccountantService.AddClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BusinessAccountantService"
        mc:Ignorable="d"
        Title="Новый клиент — BIKE LAB" Height="420" Width="400" 
        WindowStartupLocation="CenterOwner" Background="#F5F6FA"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- 1. ОСНОВНАЯ КНОПКА (Сохранить/Добавить) -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 2. ВТОРОСТЕПЕННАЯ КНОПКА (Отмена) -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="Background" Value="#E0E2E6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D1D4D9"/>
                    <Setter Property="Foreground" Value="#2C3E50"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 3. СТИЛЬ ПОЛЕЙ ВВОДА -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#DCDDE1"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Margin" Value="0,5,0,18"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#3498DB"/>
                    <Setter Property="Background" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Заголовок -->
            <RowDefinition Height="*"/>
            <!-- Форма -->
            <RowDefinition Height="Auto"/>
            <!-- Кнопки -->
        </Grid.RowDefinitions>

        <!-- ШАПКА -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="ДОБАВЛЕНИЕ КЛИЕНТА" FontSize="20" FontWeight="Black" Foreground="#2C3E50"/>
            <Separator Height="2" Background="#3498DB" Width="40" HorizontalAlignment="Left" Margin="2,5,0,0"/>
        </StackPanel>

        <!-- ФОРМА -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="ФИО КЛИЕНТА" FontSize="10" FontWeight="Bold" Foreground="#95A5A6" Margin="2,0,0,0"/>
            <TextBox x:Name="FullNameBox" />

            <TextBlock Text="НОМЕР ТЕЛЕФОНА" FontSize="10" FontWeight="Bold" Foreground="#95A5A6" Margin="2,0,0,0"/>
            <TextBox x:Name="PhoneBox" />

            <TextBlock Text="АДРЕС ПРОЖИВАНИЯ" FontSize="10" FontWeight="Bold" Foreground="#95A5A6" Margin="2,0,0,0"/>
            <TextBox x:Name="AddressBox" />
        </StackPanel>

        <!-- КНОПКИ -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="ОТМЕНА" 
                        Style="{StaticResource SecondaryButtonStyle}" 
                        Click="CancelButton_Click" 
                        Width="100" Margin="0,0,10,0"/>

                <Button Content="СОХРАНИТЬ" 
                        Style="{StaticResource PrimaryButtonStyle}" 
                        Background="#27AE60" 
                        Click="SaveButton_Click" 
                        Width="140"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>