<Window x:Class="BusinessAccountantService.AddManualExpenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BusinessAccountantService"
        mc:Ignorable="d"
        Title="Прочий расход" Height="350" Width="350" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="НЕМАТЕРИАЛЬНЫЙ РАСХОД" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" Foreground="#E67E22"/>

            <Label Content="Описание (на что потрачено):"/>
            <TextBox x:Name="DescBox" Margin="0,0,0,10" Height="28" VerticalContentAlignment="Center"/>

            <Label Content="Сумма (₽):" Foreground="#C0392B" FontWeight="Bold"/>
            <TextBox x:Name="AmountBox" Margin="0,0,0,10" Height="28" VerticalContentAlignment="Center"/>

            <Label Content="Категория:"/>
            <ComboBox x:Name="CategoryBox" IsEditable="True" Margin="0,0,0,20">
                <ComboBoxItem Content="Аренда"/>
                <ComboBoxItem Content="Налоги"/>
                <ComboBoxItem Content="Коммуналка"/>
                <ComboBoxItem Content="Реклама"/>
                <ComboBoxItem Content="Инструмент"/>
                <ComboBoxItem Content="Прочее"/>
            </ComboBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Записать" Click="Save_Click" Width="120" Height="35" Background="#E67E22" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                <Button Content="Отмена" Click="Cancel_Click" Width="80" Height="35" Margin="10,0,0,0"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
