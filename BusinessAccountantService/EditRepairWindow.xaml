<Window x:Class="BusinessAccountantService.EditRepairWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BusinessAccountantService.Managers"
        mc:Ignorable="d"
        Title="Редактирование заказа" Height="750" Width="600" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <local:StatusColorConverter x:Key="StatusColorConverter"/>
    </Window.Resources>

    <Grid Background="#F5F6FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Шапка -->
            <RowDefinition Height="*"/>
            <!-- Контент -->
            <RowDefinition Height="Auto"/>
            <!-- Итоги -->
        </Grid.RowDefinitions>

        <!-- 0: ШАПКА -->
        <Border Grid.Row="0" Background="White" Padding="20,15" BorderBrush="#DCDDE1" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="РЕДАКТИРОВАНИЕ ЗАКАЗА" FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
                    <TextBlock x:Name="OrderDateText" Text="Заказ от ..." FontSize="11" Foreground="Gray"/>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <Label Content="Статус заказа:" FontSize="11" Foreground="Gray" Padding="0,0,0,2"/>

                    <!-- Привязываемся к контенту выбранного элемента -->
                    <Border x:Name="StatusBorder" 
            Background="{Binding SelectedItem.Content, ElementName=StatusComboBox, Converter={StaticResource StatusColorConverter}}" 
            CornerRadius="7" 
            Padding="5">

                        <ComboBox x:Name="StatusComboBox" 
                  Height="26" 
                  VerticalContentAlignment="Center" 
                  FontWeight="SemiBold"
                  Background="Transparent" 
                  BorderThickness="0">
                            <ComboBoxItem Content="Принят" IsSelected="True"/>
                            <ComboBoxItem Content="В работе"/>
                            <ComboBoxItem Content="Готов"/>
                            <Separator/>
                            <ComboBoxItem Content="Выдан" Foreground="DarkGreen" FontWeight="Bold"/>
                        </ComboBox>
                    </Border>
                </StackPanel>

            </Grid>
        </Border>

        <!-- 1: КОНТЕНТ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <Label Content="Информация о велосипеде:" FontWeight="SemiBold"/>
                <TextBox x:Name="BikeInfoBox" Margin="0,0,0,15" Padding="5" Height="28" VerticalContentAlignment="Center"/>

                <Label Content="Описание проблемы:" FontWeight="SemiBold"/>
                <TextBox x:Name="ProblemBox" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,20" Padding="5"/>

                <GroupBox Header="Состав работ и запчастей" BorderBrush="#3498DB" BorderThickness="1">
                    <StackPanel Margin="5">
                        <DataGrid x:Name="OrderItemsGrid" Height="250" AutoGenerateColumns="False" 
                                  CanUserAddRows="False" SelectionMode="Single" Background="White"
                                  BorderThickness="0" GridLinesVisibility="Horizontal" RowHeight="35"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Тип" Binding="{Binding TypeDisplay}" Width="80" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="60"/>
                                <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat={}{0:N0}}" Width="90"/>
                                <DataGridTextColumn Header="Итого" Binding="{Binding Total, StringFormat={}{0:N0} ₽}" Width="90" IsReadOnly="True" FontWeight="Bold"/>
                                <DataGridTemplateColumn x:Name="DeleteColumn" Width="40">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="✕" Click="RemoveItem_Click" Background="Transparent" BorderThickness="0" Foreground="#E74C3C" FontSize="14"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <UniformGrid Columns="2" Margin="0,10,0,0">
                            <Button x:Name="BtnOpenPartSearch" Content="+ ЗАПЧАСТЬ" Click="OpenPartSearch_Click" Height="40" Background="#2980B9" Foreground="White" FontWeight="Bold" Margin="0,0,5,0"/>
                            <Button x:Name="BtnOpenServiceSearch" Content="+ РАБОТА" Click="OpenServiceSearch_Click" Height="40" Background="#27AE60" Foreground="White" FontWeight="Bold" Margin="5,0,0,0"/>
                        </UniformGrid>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- 2: НИЖНЯЯ ПАНЕЛЬ -->
        <Border Grid.Row="2" Background="White" Padding="20,15" BorderBrush="#DCDDE1" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ProfitText" Text="Чистая прибыль: 0 руб." FontSize="14" FontWeight="Bold" Foreground="#2980B9" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="ИТОГО:" FontSize="22" FontWeight="Black" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <TextBlock x:Name="TotalCostText" Text="0 ₽" FontSize="22" FontWeight="Black" Foreground="#27AE60" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <Button x:Name="BtnDelete" Content="Удалить заказ" Width="130" Height="35" HorizontalAlignment="Left" Click="Delete_Click" Background="#E74C3C" Foreground="White" BorderThickness="0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnSave" Content="Сохранить" Width="120" Height="35" Click="Save_Click" Background="#27AE60" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                        <Button Content="Отмена" Width="100" Height="35" Margin="10,0,0,0" Click="Cancel_Click" Background="#BDC3C7" BorderThickness="0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
