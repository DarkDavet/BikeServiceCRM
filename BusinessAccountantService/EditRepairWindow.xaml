<Window x:Class="BusinessAccountantService.EditRepairWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BusinessAccountantService"
        mc:Ignorable="d"
        Title="EditRepairWindow" Height="600" Width="500" WindowStartupLocation="CenterOwner">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            
            <StackPanel Margin="20">
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <!-- Заголовок займет всё свободное место -->
                        <ColumnDefinition Width="180"/>
                        <!-- Фиксированная ширина для комбобокса -->
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Редактирование заказа" 
               FontSize="18" 
               FontWeight="Bold" 
               VerticalAlignment="Bottom"/>

                    <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                        <Label Content="Статус заказа:" FontSize="11" Foreground="Gray" Margin="0,0,0,-3"/>
                        <ComboBox x:Name="StatusComboBox" Height="28" VerticalContentAlignment="Center">
                            <ComboBoxItem Content="Принят"/>
                            <ComboBoxItem Content="В работе"/>
                            <ComboBoxItem Content="Готов"/>
                            <ComboBoxItem Content="Выдан"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>


                <Label Content="Информация о велосипеде:"/>
            <TextBox x:Name="BikeInfoBox" Margin="0,0,0,10"/>

            <Label Content="Описание проблемы:"/>
            <TextBox x:Name="ProblemBox" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10"/>
                <GroupBox Header="Быстрый расчет со склада" Margin="0,0,0,10">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <!-- Название (ComboBox) -->
                            <ColumnDefinition Width="80"/>
                            <!-- Цена -->
                            <ColumnDefinition Width="Auto"/>
                            <!-- Кнопка + -->
                            <ColumnDefinition Width="Auto"/>
                            <!-- Кнопка Reset -->
                        </Grid.ColumnDefinitions>

                        <!-- IsEditable="True" позволяет и искать, и писать свой текст -->
                        <ComboBox x:Name="ItemSearchBox" Grid.Column="0" Margin="0,0,5,0" Height="25" 
                  IsEditable="True" StaysOpenOnEdit="True" IsTextSearchEnabled="False"
                  DisplayMemberPath="Name" TextSearch.TextPath="Name"
                  SelectionChanged="ItemSearchBox_SelectionChanged"
                  KeyUp="ItemSearchBox_KeyUp"/>

                        <TextBox x:Name="ItemPriceBox" Grid.Column="1" Margin="0,0,5,0" Height="25" VerticalContentAlignment="Center"/>

                        <Button Content="+" Grid.Column="2" Width="30" Click="AddItem_Click" Background="#3498DB" Foreground="White" FontWeight="Bold"/>
                        <Button Content="Reset" Grid.Column="3" Width="50" Margin="5,0,0,0" Click="ClearCosts_Click" Background="#95A5A6" Foreground="White" FontSize="10"/>
                    </Grid>
                </GroupBox>

                <Label Content="Выполненные работы:"/>
            <TextBox x:Name="WorksBox" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10"/>

            <!-- НОВЫЙ БЛОК ДЛЯ РАСХОДОВ И ПРИБЫЛИ -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <Label Content="Расходы (запчасти):" Foreground="#C0392B" FontWeight="Bold"/>
                    <TextBox x:Name="PartsCostBox" Height="28" VerticalContentAlignment="Center" TextChanged="CostFields_TextChanged"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                    <Label Content="Итого к оплате:" Foreground="#27AE60" FontWeight="Bold"/>
                    <TextBox x:Name="TotalCostBox" Height="28" VerticalContentAlignment="Center" TextChanged="CostFields_TextChanged"/>
                </StackPanel>
            </Grid>

            <TextBlock x:Name="ProfitText" Text="Чистая прибыль: 0 руб." 
                       HorizontalAlignment="Right" FontSize="14" FontWeight="Bold" Foreground="#2980B9" Margin="0,0,0,20"/>
            <!-- КОНЕЦ НОВОГО БЛОКА -->

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Удалить заказ" Width="120" Height="30" Margin="0,0,70,0" 
                        Click="Delete_Click" Background="#C0392B" Foreground="White"/>
                    <Button Content="Сохранить" Width="100" Height="30" Margin="0,0,10,0" 
                        Click="Save_Click" Background="#27AE60" Foreground="White"/>
                <Button Content="Отмена" Width="100" Height="30" Click="Cancel_Click"/>
            </StackPanel>
        </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
