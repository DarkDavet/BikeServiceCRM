<Window x:Class="BusinessAccountantService.EditRepairWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BusinessAccountantService"
        mc:Ignorable="d"
        Title="EditRepairWindow" Height="550" Width="800">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <TextBlock Text="Редактирование заказа" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

            <Label Content="Информация о велосипеде:"/>
            <TextBox x:Name="BikeInfoBox" Margin="0,0,0,10"/>

            <Label Content="Описание проблемы:"/>
            <TextBox x:Name="ProblemBox" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10"/>
            <GroupBox Header="Быстрое добавление запчастей/работ" Margin="0,0,0,10">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <!-- Название -->
                        <ColumnDefinition Width="80"/>
                        <!-- Цена -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Кнопка -->
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="ItemNameBox" Grid.Column="0" Margin="0,0,5,0" Tag="Название запчасти или работы..."/>
                    <TextBox x:Name="ItemPriceBox" Grid.Column="1" Margin="0,0,5,0" Tag="Цена"/>
                    <Button Content="+" Grid.Column="2" Width="30" Click="AddItem_Click" Background="#3498DB" Foreground="White" FontWeight="Bold"/>
                </Grid>
            </GroupBox>
            <Label Content="Выполненные работы:"/>
            <TextBox x:Name="WorksBox" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10"/>

            <!-- НОВЫЙ БЛОК ДЛЯ РАСХОДОВ И ПРИБЫЛИ -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <Label Content="Расходы (запчасти):" Foreground="#C0392B" FontWeight="Bold"/>
                    <TextBox x:Name="PartsCostBox" Height="28" VerticalContentAlignment="Center" TextChanged="CostFields_TextChanged"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                    <Label Content="Итого к оплате:" Foreground="#27AE60" FontWeight="Bold"/>
                    <TextBox x:Name="TotalCostBox" Height="28" VerticalContentAlignment="Center" TextChanged="CostFields_TextChanged"/>
                </StackPanel>
            </Grid>

            <TextBlock x:Name="ProfitText" Text="Чистая прибыль: 0 руб." 
                       HorizontalAlignment="Right" FontSize="14" FontWeight="Bold" Foreground="#2980B9" Margin="0,0,0,20"/>
            <!-- КОНЕЦ НОВОГО БЛОКА -->

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Удалить заказ" Width="120" Margin="0,0,50,0" 
                        Click="Delete_Click" Background="#C0392B" Foreground="White"/>
                <Button Content="Сохранить" Width="100" Margin="0,0,10,0" 
                        Click="Save_Click" Background="#27AE60" Foreground="White"/>
                <Button Content="Отмена" Width="100" Click="Cancel_Click"/>
            </StackPanel>
        </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
