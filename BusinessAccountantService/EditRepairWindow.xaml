<Window x:Class="BusinessAccountantService.EditRepairWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BusinessAccountantService.Managers"
        mc:Ignorable="d"
        Title="Детали заказа — BIKE LAB" Height="800" Width="650" 
        WindowStartupLocation="CenterOwner" Background="#F5F6FA">

    <Window.Resources>
        <local:StatusColorConverter x:Key="StatusColorConverter"/>
        <!-- КНОПКИ (Твой новый стандарт) -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="Background" Value="#E0E2E6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#E74C3C"/>
            <Setter Property="Background" Value="#FDECEA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E74C3C"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#DCDDE1"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="White"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#3498DB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Шапка -->
            <RowDefinition Height="*"/>
            <!-- Контент -->
            <RowDefinition Height="Auto"/>
            <!-- Подвал (Итого) -->
        </Grid.RowDefinitions>

        <!-- РЯД 0: ШАПКА -->
        <Border Grid.Row="0" Background="White" Padding="25,20" BorderBrush="#DCDDE1" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="ЗАКАЗ" FontSize="22" FontWeight="Black" Foreground="#2C3E50"/>
                        <TextBlock x:Name="OrderIdText" Text="№000" FontSize="22" FontWeight="Black" Foreground="#3498DB" Margin="8,0,0,0"/>
                    </StackPanel>
                    <TextBlock x:Name="ClientNameText" Text="Загрузка клиента..." FontSize="14" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,4,0,0"/>
                    <TextBlock x:Name="OrderDateText" Text="Заказ от ..." FontSize="11" Foreground="#BDC3C7" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="СТАТУС ЗАКАЗА" FontSize="10" FontWeight="Bold" Foreground="#95A5A6" Margin="5,0,0,5"/>

                    <!-- Border теперь снова привязан к конвертеру и меняет цвет в зависимости от выбранного статуса -->
                    <Border x:Name="StatusBorder" 
            Background="{Binding SelectedItem.Content, ElementName=StatusComboBox, Converter={StaticResource StatusColorConverter}}" 
            CornerRadius="8" 
            Padding="3">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.1"/>
                        </Border.Effect>

                        <ComboBox x:Name="StatusComboBox" 
                  Height="32" 
                  VerticalContentAlignment="Center" 
                  FontWeight="Black" 
                  FontSize="13"
                  Background="Transparent" 
                  BorderThickness="0">
                            <!-- Стилизуем сами пункты выпадающего списка -->
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Padding" Value="10,5"/>
                                    <Style.Triggers>
                                        <!-- ПРИНЯТ: делаем нейтральным (белым или темно-серым) -->
                                        <DataTrigger Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="Принят">
                                            <Setter Property="Foreground" Value="#7F8C8D"/>
                                            <!-- Элегантный серый, чтобы не сливался с белым фоном -->
                                        </DataTrigger>

                                        <!-- В РАБОТЕ: меняем на твой фирменный синий -->
                                        <DataTrigger Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="В работе">
                                            <Setter Property="Foreground" Value="#3498DB"/>
                                        </DataTrigger>

                                        <!-- ГОТОВ: оставляем зеленым -->
                                        <DataTrigger Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="Готов">
                                            <Setter Property="Foreground" Value="#27AE60"/>
                                        </DataTrigger>

                                        <!-- ВЫДАН: темный статус -->
                                        <DataTrigger Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="Выдан">
                                            <Setter Property="Foreground" Value="#2C3E50"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ComboBox.ItemContainerStyle>

                            <ComboBoxItem Content="Принят"/>
                            <ComboBoxItem Content="В работе"/>
                            <ComboBoxItem Content="Готов"/>
                            <Separator/>
                            <ComboBoxItem Content="Выдан" FontWeight="Black"/>
                        </ComboBox>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- РЯД 1: КОНТЕНТ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="25">
                <!-- ИНФО О БАЙКЕ -->
                <TextBlock Text="ДАННЫЕ ВЕЛОСИПЕДА" FontSize="10" FontWeight="Bold" Foreground="#95A5A6" Margin="2,0,0,5"/>
                <TextBox x:Name="BikeInfoBox" Height="40" VerticalContentAlignment="Center" Margin="0,0,0,20" Padding="12,0"/>

                <TextBlock Text="ОПИСАНИЕ ПРОБЛЕМЫ" FontSize="10" FontWeight="Bold" Foreground="#95A5A6" Margin="2,0,0,5"/>
                <TextBox x:Name="ProblemBox" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,25" Padding="12"/>

                <!-- ТАБЛИЦА РАБОТ -->
                <TextBlock Text="СОСТАВ ЗАКАЗА (РАБОТЫ И ЗАПЧАСТИ)" FontSize="10" FontWeight="Bold" Foreground="#95A5A6" Margin="2,0,0,5"/>
                <Border Background="White" CornerRadius="10" BorderBrush="#DCDDE1" BorderThickness="1" Padding="5">
                    <StackPanel>
                        <DataGrid x:Name="OrderItemsGrid" Height="200" AutoGenerateColumns="False" CanUserAddRows="False" 
                                  Background="Transparent" BorderThickness="0" GridLinesVisibility="Horizontal" 
                                  HorizontalGridLinesBrush="#F1F2F6" RowHeight="40" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="*" FontWeight="SemiBold"/>
                                <DataGridTextColumn Header="Тип" Binding="{Binding TypeDisplay}" Width="80"/>
                                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="60"/>
                                <DataGridTextColumn Header="Итого" Binding="{Binding Total, StringFormat={}{0:N2} ₽}" Width="100" FontWeight="Black"/>
                                <DataGridTemplateColumn x:Name="DeleteColumn" Width="45">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="✕" Click="RemoveItem_Click" Background="Transparent" BorderThickness="0" 
                                                    Foreground="#E74C3C" FontWeight="Bold" FontSize="14" Cursor="Hand"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Кнопки добавления -->
                        <UniformGrid Columns="2" Margin="5">
                            <Button x:Name="BtnOpenPartSearch" Content="+ ЗАПЧАСТЬ" Style="{StaticResource PrimaryButtonStyle}" 
                                    Background="#3498DB" Click="OpenPartSearch_Click" Margin="0,0,5,0"/>
                            <Button x:Name="BtnOpenServiceSearch" Content="+ РАБОТА" Style="{StaticResource PrimaryButtonStyle}" 
                                    Background="#27AE60" Click="OpenServiceSearch_Click" Margin="5,0,0,0"/>
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- РЯД 2: ФУТЕР С ИТОГАМИ -->
        <Border Grid.Row="2" Background="White" Padding="25" BorderBrush="#DCDDE1" BorderThickness="0,1,0,0">
            <StackPanel>
                <!-- ФИНАНСЫ -->
                <Grid Margin="0,0,0,25">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="ProfitText" Text="Чистая прибыль: 0 BYN" FontSize="14" FontWeight="Bold" Foreground="#3498DB"/>
                        <TextBlock Text="только с учётом расходов на запчасти" FontSize="10" Foreground="#BDC3C7"/>
                    </StackPanel>

                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <TextBlock Text="ИТОГО К ОПЛАТЕ:" FontSize="12" FontWeight="Bold" Foreground="#95A5A6" VerticalAlignment="Bottom" Margin="0,0,15,4"/>
                        <TextBlock x:Name="TotalCostText" Text="0 BYN" FontSize="32" FontWeight="Black" Foreground="#27AE60"/>
                    </StackPanel>
                </Grid>

                <!-- КНОПКИ ДЕЙСТВИЙ -->
                <Grid>
                    <Button x:Name="BtnDelete" Content="УДАЛИТЬ ЗАКАЗ" Style="{StaticResource DangerButtonStyle}" 
                            HorizontalAlignment="Left" Click="Delete_Click" Width="140"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="ОТМЕНА" Style="{StaticResource SecondaryButtonStyle}" 
                                Click="Cancel_Click" Width="100" Margin="0,0,10,0"/>
                        <Button x:Name="BtnSave" Content="СОХРАНИТЬ ИЗМЕНЕНИЯ" Style="{StaticResource PrimaryButtonStyle}" 
                                Background="#27AE60" Click="Save_Click" Width="200"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>