<Window x:Class="BusinessAccountantService.ScrapItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BusinessAccountantService"
        mc:Ignorable="d"
        Title="Списание остатков" Height="250" Width="350" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="СПИСАНИЕ СО СКЛАДА" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" Foreground="#E67E22"/>

            <TextBlock x:Name="ItemNameText" Text="Товар: ..." FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBlock x:Name="CurrentQtyText" Text="В наличии: 0 шт." Foreground="Gray" Margin="0,0,0,15"/>

            <Label Content="Сколько штук списать?"/>
            <TextBox x:Name="ScrapQtyBox" Height="30" VerticalContentAlignment="Center" FontSize="16" FontWeight="Bold"/>

            <UniformGrid Columns="2" Margin="0,20,0,0">
                <Button Content="ПОДТВЕРДИТЬ" Click="ConfirmScrap_Click" Height="35" Background="#E67E22" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                <Button Content="Отмена" Click="Cancel_Click" Height="35" Margin="10,0,0,0"/>
            </UniformGrid>
        </StackPanel>
    </Grid>
</Window>
