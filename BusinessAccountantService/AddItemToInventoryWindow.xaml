<Window x:Class="BusinessAccountantService.AddItemToInventoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Приход товара — BIKE LAB" Height="520" Width="420" 
        WindowStartupLocation="CenterOwner" Background="#F5F6FA"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- ОСНОВНАЯ КНОПКА (Добавить) -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ВТОРОСТЕПЕННАЯ КНОПКА (Отмена) -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="Background" Value="#E0E2E6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D1D4D9"/>
                    <Setter Property="Foreground" Value="#2C3E50"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- СТИЛЬ ПОЛЕЙ ВВОДА -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#DCDDE1"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Margin" Value="0,5,0,12"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#3498DB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0,5,0,12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <StackPanel>
            <!-- ШАПКА -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="ПРИХОД ТОВАРА" FontSize="20" FontWeight="Black" Foreground="#2C3E50"/>
                <Separator Height="2" Background="#27AE60" Width="40" HorizontalAlignment="Left" Margin="2,5,0,0"/>
            </StackPanel>

            <TextBlock Text="КАТЕГОРИЯ" FontSize="9" FontWeight="Bold" Foreground="#95A5A6" Margin="2,0,0,0"/>
            <ComboBox x:Name="CategoryBox" IsEditable="True" SelectionChanged="CategoryBox_SelectionChanged">
                <ComboBoxItem Content="Запчасти"/>
                <ComboBoxItem Content="Инструменты"/>
                <ComboBoxItem Content="Химия/Средства"/>
                <ComboBoxItem Content="Инвентарь"/>
                <ComboBoxItem Content="Другое"/>
            </ComboBox>

            <TextBlock Text="НАИМЕНОВАНИЕ ТОВАРА" FontSize="9" FontWeight="Bold" Foreground="#95A5A6" Margin="2,0,0,0"/>
            <TextBox x:Name="ItemNameBox" />

            <TextBlock Text="КОЛИЧЕСТВО" FontSize="9" FontWeight="Bold" Foreground="#95A5A6" Margin="2,0,0,0"/>
            <TextBox x:Name="QuantityBox" Text="1" />

            <!-- БЛОК ЦЕН В КАРТОЧКЕ -->
            <Border Background="White" CornerRadius="10" BorderBrush="#DCDDE1" BorderThickness="1" Padding="15" Margin="0,5,0,25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="1" Opacity="0.05"/>
                </Border.Effect>
                <StackPanel>
                    <CheckBox x:Name="BulkModeCheck" Content="Закупка оптом (всей партией)" 
                              Margin="0,0,0,10" FontWeight="SemiBold" Foreground="#2980B9"
                              Visibility="Collapsed"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- ЗАКУПКА -->
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, ElementName=BulkModeCheck}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="ЗАКУПКА (1 ШТ)" FontSize="9" FontWeight="Bold" Foreground="#E74C3C"/>
                            <TextBox x:Name="PurchasePriceBox" Text="0" Margin="0,5,0,0"/>
                        </StackPanel>
                        <!-- СУММА ПАРТИИ -->
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, ElementName=BulkModeCheck}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="СУММА ПАРТИИ" FontSize="9" FontWeight="Bold" Foreground="#2980B9"/>
                            <TextBox x:Name="BulkTotalBox" Text="0" Background="#EBF5FB" Margin="0,5,0,0"/>
                        </StackPanel>
                        <!-- ЦЕНА РОЗНИЦА -->
                        <StackPanel x:Name="RetailPriceBlock" Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="ЦЕНА РОЗНИЦА" FontSize="9" FontWeight="Bold" Foreground="#27AE60"/>
                            <TextBox x:Name="RetailPriceBox" Text="0" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- КНОПКИ -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="ОТМЕНА" Style="{StaticResource SecondaryButtonStyle}" 
                        Click="Cancel_Click" Width="100" Margin="0,0,10,0"/>

                <Button Content="ДОБАВИТЬ" Style="{StaticResource PrimaryButtonStyle}" 
                        Background="#27AE60" Click="SaveItem_Click" Width="140"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
