<Window x:Class="BusinessAccountantService.AddItemToInventoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Приход товара" Height="450" Width="400" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="ДОБАВЛЕНИЕ ТОВАРА НА СКЛАД" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" Foreground="#2C3E50"/>

            <Label Content="Категория:"/>
            <ComboBox x:Name="CategoryBox" IsEditable="True" Margin="0,0,0,10" 
                      SelectionChanged="CategoryBox_SelectionChanged">
                <ComboBoxItem Content="Запчасти"/>
                <ComboBoxItem Content="Расходники"/>
                <ComboBoxItem Content="Велосипеды"/>
                <ComboBoxItem Content="Аксессуары"/>
            </ComboBox>

            <Label Content="Наименование товара:"/>
            <TextBox x:Name="ItemNameBox" Margin="0,0,0,10" Height="28" VerticalContentAlignment="Center"/>

            <Label Content="Количество:"/>
            <TextBox x:Name="QuantityBox" Text="1" Margin="0,0,0,10" Height="28" VerticalContentAlignment="Center"/>

            <!-- БЛОК ЗАКУПКИ (ОПТ / РОЗНИЦА) -->
            <Border Background="#F9F9F9" CornerRadius="5" Padding="10" Margin="0,5,0,15" BorderBrush="#DCDDE1" BorderThickness="1">
                <StackPanel>
                    <CheckBox x:Name="BulkModeCheck" Content="Закупка оптом (всей партией)" 
                              Margin="0,0,0,10" FontWeight="SemiBold" Foreground="#2980B9"
                              Visibility="Collapsed"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ПОЛЕ 1: Цена за 1 шт -->
                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, ElementName=BulkModeCheck}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Label Content="Закупка (за 1 шт):" Foreground="#C0392B" FontWeight="Bold"/>
                            <TextBox x:Name="PurchasePriceBox" Text="0" Height="28" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <!-- ПОЛЕ 2: Сумма за партию (Видно только если BulkModeCheck.IsChecked == True) -->
                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, ElementName=BulkModeCheck}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Label Content="Сумма за партию:" Foreground="#2980B9" FontWeight="Bold"/>
                            <TextBox x:Name="BulkTotalBox" Text="0" Height="28" VerticalContentAlignment="Center" Background="#EBF5FB"/>
                        </StackPanel>

                        <!-- ПОЛЕ РОЗНИЦЫ -->
                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                            <Label Content="Цена розница:" Foreground="#27AE60" FontWeight="Bold"/>
                            <TextBox x:Name="RetailPriceBox" Text="0" Height="28" VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Добавить" Click="SaveItem_Click" Width="120" Height="35" Background="#27AE60" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                <Button Content="Отмена" Click="Cancel_Click" Width="90" Height="35" Margin="10,0,0,0"/>
            </StackPanel>
        </StackPanel>
    </Grid>
    </Window>

