<Window x:Class="BusinessAccountantService.EditItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BusinessAccountantService"
        mc:Ignorable="d"
        Title="EditItemWindow" Height="450" Width="400">
    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="РЕДАКТИРОВАНИЕ ЗАПЧАСТИ" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" Foreground="#2C3E50"/>

            <Label Content="Наименование:"/>
            <TextBox x:Name="ItemNameBox" Margin="0,0,0,10" Height="28" VerticalContentAlignment="Center"/>

            <Label Content="Категория:"/>
            <ComboBox x:Name="CategoryBox" IsEditable="True" Margin="0,0,0,10">
                <ComboBoxItem Content="Запчасти"/>
                <ComboBoxItem Content="Расходники"/>
                <ComboBoxItem Content="Аксессуары"/>
            </ComboBox>

            <Grid Margin="0,10,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <Label Content="Цена закупки:" Foreground="#C0392B"/>
                    <TextBox x:Name="PurchaseBox" Height="28"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                    <Label Content="Цена розница:" Foreground="#27AE60"/>
                    <TextBox x:Name="RetailBox" Height="28"/>
                </StackPanel>
            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Удалить товар" Click="Delete_Click" Width="110" Margin="0,0,40,0" Background="#C0392B" Foreground="White"/>
                <Button Content="Сохранить" Click="Save_Click" Width="100" Background="#27AE60" Foreground="White"/>
                <Button Content="Отмена" Click="Cancel_Click" Width="80" Margin="10,0,0,0"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
