<Window x:Class="BusinessAccountantService.EditClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BusinessAccountantService"
        mc:Ignorable="d"
            Title="Окно редактировния" Height="350" Width="400" WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20">
        <TextBlock Text="Редактирование данных клиента" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

        <TextBlock Text="ФИО:"/>
        <TextBox x:Name="FullNameBox" Margin="0,5,0,15" Height="25"/>

        <TextBlock Text="Телефон:"/>
        <TextBox x:Name="PhoneBox" Margin="0,5,0,15" Height="25"/>

        <TextBlock Text="Адрес:"/>
        <TextBox x:Name="AddressBox" Margin="0,5,0,15" Height="25"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Удалить клиента" Width="130" Height="30" Margin="0,0,30,0" 
                    Click="Delete_Click" Background="#C0392B" Foreground="White"/>
            <Button Content="Сохранить" Width="100" Height="30" Background="#27AE60" Foreground="White" Click="Save_Click"/>
            <Button Content="Отмена" Width="80" Height="30" Margin="10,0,0,0" Click="Cancel_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
