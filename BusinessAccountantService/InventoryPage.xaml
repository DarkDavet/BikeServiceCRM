<Page x:Class="BusinessAccountantService.InventoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BusinessAccountantService.Managers"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="InventoryPage">
    <Page.Resources>
        <local:PriceToDashConverter x:Key="PriceToDashConverter"/>
    </Page.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Склад запчастей" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>

            <Label Content="Поиск:" Margin="30,0,5,0" VerticalAlignment="Center" Foreground="Gray"/>
            <TextBox x:Name="SearchBox" Width="250" Height="28" VerticalContentAlignment="Center" 
                     TextChanged="SearchBox_TextChanged" />

            <TextBlock x:Name="StatusInfoText" Text="Товаров: 0" Foreground="#2980B9" 
                       FontWeight="Bold" VerticalAlignment="Center" Margin="20,0,0,0"/>
        </StackPanel>

        <DataGrid Grid.Row="1" x:Name="InventoryGrid"
                  MouseDoubleClick="InventoryGrid_MouseDoubleClick"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="150"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="80"/>
                <DataGridTextColumn Header="Закупка" Binding="{Binding PurchasePrice, Converter={StaticResource PriceToDashConverter}}" Width="100"/>
                <DataGridTextColumn Header="Розница" Binding="{Binding RetailPrice, Converter={StaticResource PriceToDashConverter}}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2" Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="Добавить позицию" Click="AddItem_Click" 
                Width="130" Height="30" Margin="0,0,10,0" Background="#27AE60" Foreground="White" BorderThickness="0"/>
                <Button Content="Пополнить запас" Click="RefillItem_Click" 
                Width="130" Height="30" Margin="0,0,10,0" Background="#2980B9" Foreground="White" BorderThickness="0"/>
                <Button Content="Списать единицу" Click="ScrapItem_Click" 
                Width="130" Height="30" Margin="0,0,10,0" Background="#C0392B" Foreground="White" BorderThickness="0"/>
                <Button Content="Удалить позицию" Click="DeleteItem_Click" 
                Width="130" Height="30" Background="#C0392B" Foreground="White" BorderThickness="0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Прочий расход" Click="AddManualExpense_Click" 
                Width="130" Height="30" Background="#E67E22" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>