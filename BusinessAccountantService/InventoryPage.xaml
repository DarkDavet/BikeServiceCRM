<Page x:Class="BusinessAccountantService.InventoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BusinessAccountantService"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="InventoryPage">

    <Grid Margin="20">
        <!-- Добавил Margin, чтобы таблица не липла к краям -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 0: Поиск -->
            <RowDefinition Height="*"/>
            <!-- 1: Таблица склада -->
            <RowDefinition Height="Auto"/>
            <!-- 2: Кнопки -->
        </Grid.RowDefinitions>

        <!-- 0: ШАПКА -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Склад запчастей" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>

            <Label Content="Поиск:" Margin="30,0,5,0" VerticalAlignment="Center" Foreground="Gray"/>
            <TextBox x:Name="SearchBox" Width="250" Height="28" VerticalContentAlignment="Center" 
                     TextChanged="SearchBox_TextChanged" />

            <TextBlock x:Name="StatusInfoText" Text="Товаров: 0" Foreground="#2980B9" 
                       FontWeight="Bold" VerticalAlignment="Center" Margin="20,0,0,0"/>
        </StackPanel>

        <!-- 1: ТАБЛИЦА СКЛАДА -->
        <DataGrid Grid.Row="1" x:Name="InventoryGrid"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="150"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="80"/>
                <DataGridTextColumn Header="Закупка" Binding="{Binding PurchasePrice, StringFormat={}{0:N0} ₽}" Width="100"/>
                <DataGridTextColumn Header="Розница" Binding="{Binding RetailPrice, StringFormat={}{0:N0} ₽}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 2: КНОПКИ ДЕЙСТВИЙ -->
        <Grid Grid.Row="2" Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <!-- Убедитесь, что имена методов Click совпадают с C# кодом InventoryPage -->
                <Button Content="Добавить позицию" Click="AddItem_Click" 
                        Width="130" Height="30" Margin="0,0,10,0" Background="#27AE60" Foreground="White" BorderThickness="0"/>
                <Button Content="Пополнить позицию" Click="RefillItem_Click" 
                        Width="130" Height="30" Margin="0,0,10,0" Background="#27AE60" Foreground="White" BorderThickness="0"/>

                <Button Content="Списать единицу" Click="ScrapItem_Click" 
                        Width="130" Height="30" Background="#E67E22" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>