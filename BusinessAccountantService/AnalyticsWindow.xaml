<Window x:Class="BusinessAccountantService.AnalyticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BusinessAccountantService"
        mc:Ignorable="d"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        Title="Аналитика сервиса" Height="600" Width="900" Background="#F5F6FA">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Заголовок и выбор месяца -->
            <RowDefinition Height="Auto"/>
            <!-- Карточки с цифрами -->
            <RowDefinition Height="*"/>
            <!-- График -->
        </Grid.RowDefinitions>

        <!-- 0: Заголовок -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="ФИНАНСОВЫЙ ОТЧЕТ:" FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
            <DatePicker x:Name="MonthPicker" Margin="20,0,0,0" Width="150" Height="30" 
                        CalendarOpened="MonthPicker_CalendarOpened" 
                        SelectedDateChanged="MonthPicker_SelectedDateChanged"/>
        </StackPanel>

        <!-- 1: КАРТОЧКИ (Плитки) -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,20">
            <Border Background="White" Margin="5" Padding="15" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="ВЫРУЧКА" Foreground="Gray" FontSize="12"/>
                    <TextBlock x:Name="RevText" Text="0 ₽" FontSize="20" FontWeight="Bold" Foreground="#2980B9"/>
                </StackPanel>
            </Border>
            <Border Background="White" Margin="5" Padding="15" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="ЗАПЧАСТИ" Foreground="Gray" FontSize="12"/>
                    <TextBlock x:Name="PartsText" Text="0 ₽" FontSize="20" FontWeight="Bold" Foreground="#C0392B"/>
                </StackPanel>
            </Border>
            <Border Background="White" Margin="5" Padding="15" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="ПРИБЫЛЬ" Foreground="Gray" FontSize="12"/>
                    <TextBlock x:Name="ProfitText" Text="0 ₽" FontSize="20" FontWeight="Bold" Foreground="#27AE60"/>
                </StackPanel>
            </Border>
            <Border Background="White" Margin="5" Padding="15" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="ЗАКАЗОВ" Foreground="Gray" FontSize="12"/>
                    <TextBlock x:Name="CountText" Text="0" FontSize="20" FontWeight="Bold" Foreground="#8E44AD"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- 2: ГРАФИК -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="20">
            <lvc:CartesianChart x:Name="FinanceChart" LegendLocation="Bottom">
                <lvc:CartesianChart.AxisX>
                    <lvc:Axis Title="Дни месяца" Labels="{Binding Labels}"/>
                </lvc:CartesianChart.AxisX>
                <lvc:CartesianChart.AxisY>
                    <lvc:Axis Title="Сумма (₽)"/>
                </lvc:CartesianChart.AxisY>
            </lvc:CartesianChart>
        </Border>
    </Grid>
</Window>
