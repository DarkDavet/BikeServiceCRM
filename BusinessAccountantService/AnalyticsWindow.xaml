<Window x:Class="BusinessAccountantService.AnalyticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BusinessAccountantService"
        mc:Ignorable="d"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        Title="Аналитика сервиса" Height="650" Width="950" Background="#F5F6FA">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 0: Шапка -->
            <RowDefinition Height="Auto"/>
            <!-- 1: Карточки -->
            <RowDefinition Height="*"/>
            <!-- 2: Вкладки -->
        </Grid.RowDefinitions>

        <!-- Строка 0: ШАПКА -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5,0,0,15">
            <TextBlock Text="АНАЛИТИКА СЕРВИСА" FontSize="22" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>
            <DatePicker x:Name="MonthPicker" Margin="25,0,0,0" Width="180" Height="30" 
                    VerticalContentAlignment="Center"
                    CalendarOpened="MonthPicker_CalendarOpened" 
                    SelectedDateChanged="MonthPicker_SelectedDateChanged"/>
        </StackPanel>

        <!-- Строка 1: КАРТОЧКИ -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,10">
            <Border x:Name="CardRev" MouseDown="Card_MouseDown" Tag="Revenue" Cursor="Hand" 
                BorderBrush="#2980B9" BorderThickness="2" Background="White" Margin="5" Padding="15" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1" Color="Black"/>
                </Border.Effect>
                <StackPanel IsHitTestVisible="False">
                    <TextBlock Text="ВЫРУЧКА" Foreground="Gray" FontSize="11"/>
                    <TextBlock x:Name="RevText" Text="0 ₽" FontSize="18" FontWeight="Bold" Foreground="#2980B9"/>
                </StackPanel>
            </Border>

            <Border x:Name="CardParts" MouseDown="Card_MouseDown" Tag="Parts" Cursor="Hand" 
                BorderBrush="Transparent" BorderThickness="2" Background="White" Margin="5" Padding="15" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1" Color="Black"/>
                </Border.Effect>
                <StackPanel IsHitTestVisible="False">
                    <TextBlock Text="ЗАПЧАСТИ" Foreground="Gray" FontSize="11"/>
                    <TextBlock x:Name="PartsText" Text="0 ₽" FontSize="18" FontWeight="Bold" Foreground="#C0392B"/>
                </StackPanel>
            </Border>

            <Border x:Name="CardProfit" MouseDown="Card_MouseDown" Tag="Profit" Cursor="Hand" 
                BorderBrush="Transparent" BorderThickness="2" Background="White" Margin="5" Padding="15" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1" Color="Black"/>
                </Border.Effect>
                <StackPanel IsHitTestVisible="False">
                    <TextBlock Text="ПРИБЫЛЬ" Foreground="Gray" FontSize="11"/>
                    <TextBlock x:Name="ProfitText" Text="0 ₽" FontSize="18" FontWeight="Bold" Foreground="#27AE60"/>
                </StackPanel>
            </Border>

            <Border x:Name="CardOrders" MouseDown="Card_MouseDown" Tag="Orders" Cursor="Hand" 
                BorderBrush="Transparent" BorderThickness="2" Background="White" Margin="5" Padding="15" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1" Color="Black"/>
                </Border.Effect>
                <StackPanel IsHitTestVisible="False">
                    <TextBlock Text="ЗАКАЗОВ" Foreground="Gray" FontSize="11"/>
                    <TextBlock x:Name="CountText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#8E44AD"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Строка 2: Вкладки -->
        <TabControl x:Name="MainTabControl" Grid.Row="2" Background="Transparent" BorderThickness="0" 
                SelectionChanged="TabControl_SelectionChanged">

            <TabItem Header="Анализ месяца" FontSize="14" Padding="15,5">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Подпись периода -->
                        <RowDefinition Height="*"/>
                        <!-- Контент -->
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="MonthLabel" HorizontalAlignment="Right" FontSize="14" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,10,5"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <!-- График (70%) -->
                            <ColumnDefinition Width="1*"/>
                            <!-- Расходы (30%) -->
                        </Grid.ColumnDefinitions>

                        <!-- ГРАФИК -->
                        <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                            <lvc:CartesianChart x:Name="FinanceChart" LegendLocation="Bottom"/>
                        </Border>

                        <!-- ДЕТАЛИЗАЦИЯ РАСХОДОВ -->
                        <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <!-- Заголовок -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Круг -->
                                    <RowDefinition Height="*"/>
                                    <!-- Список -->
                                </Grid.RowDefinitions>

                                <TextBlock Text="СТРУКТУРА ТРАТ" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                                <lvc:PieChart Grid.Row="1" x:Name="ExpensesPieChart" Height="180" LegendLocation="Bottom" Hoverable="True"/>

                                <DataGrid Grid.Row="2" x:Name="ExpensesDetailGrid" Margin="0,10,0,0" 
                                          AutoGenerateColumns="False" IsReadOnly="True" Background="Transparent" BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Дата" Binding="{Binding DateFormatted}" Width="85"/>
                                        <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*"/>
                                        <DataGridTextColumn Header="Сумма" Binding="{Binding Amount, StringFormat={}{0:N0} ₽}" Width="Auto"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Динамика года" FontSize="14" Padding="15,5">
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <!-- Столбчатый график -->
                        <ColumnDefinition Width="1*"/>
                        <!-- Годовая диаграмма -->
                    </Grid.ColumnDefinitions>

                    <!-- Существующий YearlyChart -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="YearLabel" Grid.Row="0" HorizontalAlignment="Right" FontSize="14" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,10,5"/>
                        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15">
                            <lvc:CartesianChart x:Name="YearlyChart" LegendLocation="Bottom"/>
                        </Border>
                    </Grid>

                    <!-- НОВАЯ КРУГОВАЯ ДИАГРАММА ЗА ГОД -->
                    <Border Grid.Column="1" Background="White" CornerRadius="8" Margin="10,32,0,0" Padding="15">
                        <StackPanel>
                            <TextBlock Text="РАСХОДЫ ЗА ГОД" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                            <lvc:PieChart x:Name="YearlyExpensesPieChart" Height="250" LegendLocation="Bottom" Hoverable="True"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
