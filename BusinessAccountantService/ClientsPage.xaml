<Page x:Class="BusinessAccountantService.ClientsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BusinessAccountantService.Managers" 
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ClientsPage">
    <Page.Resources>
        <local:StatusColorConverter x:Key="StatusColorConverter"/>
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock x:Name="MainTitleText" Text="Список клиентов" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>

            <Label Content="Поиск:" Margin="30,0,5,0" VerticalAlignment="Center" Foreground="Gray"/>
            <TextBox x:Name="SearchBox" Width="250" Height="28" VerticalContentAlignment="Center" TextChanged="SearchBox_TextChanged" />

            <TextBlock x:Name="StatusInfoText" Text="Клиентов: 0 | Заказов: 0" Foreground="#27AE60" FontWeight="Bold" VerticalAlignment="Center" Margin="20,0,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <DataGrid x:Name="ClientsGrid" Visibility="Visible" 
      MouseDoubleClick="ClientsGrid_MouseDoubleClick"
      AutoGenerateColumns="False" SelectionChanged="ClientsGrid_SelectionChanged" 
      CanUserAddRows="False" CanUserDeleteRows="False"
                      IsReadOnly="True"
                      >
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40"/>
                    <DataGridTextColumn Header="ФИО Клиента" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="150"/>
                    <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <StackPanel x:Name="RepairsPanel" Grid.Row="2" Visibility="Visible">
            <GridSplitter Height="5" HorizontalAlignment="Stretch" Background="#DDDDDD" Margin="0,10"/>

            <TextBlock Text="История ремонтов выбранного клиента:" FontWeight="Bold" Margin="0,0,0,5"/>
            <DataGrid x:Name="RepairsHistoryGrid" 
          Height="200"
          MouseDoubleClick="RepairsHistoryGrid_MouseDoubleClick"
          AutoGenerateColumns="False" 
          CanUserAddRows="False" 
          CanUserDeleteRows="False"
          IsReadOnly="True"
          SelectionMode="Single"
          SelectionUnit="FullRow"
          GridLinesVisibility="Horizontal"
          HeadersVisibility="Column"
          Background="White">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Дата" Binding="{Binding DateCreated, StringFormat={}{0:dd.MM.yyyy}}" Width="100"/>
                    <DataGridTextColumn Header="Велосипед" Binding="{Binding BikeInfo}" Width="150"/>
                    <DataGridTextColumn Header="Описание" Binding="{Binding ProblemDescription}" Width="*"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="120">
                        <DataGridTextColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Background" Value="{Binding Status, Converter={StaticResource StatusColorConverter}}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Итого" Binding="{Binding TotalCost, StringFormat={}{0:N2} р.}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Margin" Value="0,0,10,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>

        <Grid Grid.Row="3" Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Name="BtnAddPrimary" Content="Добавить клиента" Click="AddClient_Click" Width="130" Height="30" Margin="0,0,10,0"/>
                <Button x:Name="BtnAddSecondary" Content="Новый заказ" Click="AddRepair_Click" Width="130" Height="30"/>
            </StackPanel>

            <StackPanel x:Name="PdfButtonsPanel" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Акт приемки (PDF)" Click="EntryAct_Click" Width="140" Height="30" Margin="0,0,10,0" Background="#27AE60" Foreground="White" BorderThickness="0"/>
                <Button Content="Акт выдачи (PDF)" Click="FinalAct_Click" Width="140" Height="30" Background="#27AE60" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
