<Page x:Class="BusinessAccountantService.ClientsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BusinessAccountantService.Managers" 
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="900"
      Title="ClientsPage">

    <Page.Resources>
        <local:StatusColorConverter x:Key="StatusColorConverter"/>

        <!-- Стиль для современных кнопок страницы -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 0: Шапка -->
            <RowDefinition Height="Auto"/>
            <!-- 1: Карточки (если есть) -->
            <RowDefinition Height="*"/>
            <!-- 2: Клиенты -->
            <RowDefinition Height="Auto"/>
            <!-- 3: История -->
            <RowDefinition Height="Auto"/>
            <!-- 4: Кнопки -->
        </Grid.RowDefinitions>

        <!-- РЯД 0: ШАПКА И ПОИСК -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="MainTitleText" Text="БАЗА КЛИЕНТОВ И ЗАКАЗОВ" FontSize="24" FontWeight="Black" Foreground="#2C3E50"/>
                <TextBlock x:Name="StatusInfoText" Text="" FontSize="14" VerticalAlignment="Bottom" Margin="15,0,0,4" Foreground="#7F8C8D"/>
            </StackPanel>

            <Border Grid.Column="1" x:Name="SearchBorder" 
        Background="White" CornerRadius="10" 
        HorizontalAlignment="Right" Padding="8,2" 
        BorderBrush="#DCDDE1" BorderThickness="1.5"
        Width="280">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <!-- Подсветка при наведении или фокусе внутри -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#3498DB"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="FocusManager.GotFocus">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                            To="#3498DB" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Иконка лупы -->
                    <TextBlock Text="🔍" Grid.Column="0" VerticalAlignment="Center" 
                   Margin="5,0" Foreground="#BDC3C7" FontSize="14"/>

                    <!-- Текст-подсказка (исчезает при вводе) -->
                    <TextBlock Text="Поиск по клиентам..." Grid.Column="1" 
                   VerticalAlignment="Center" Margin="5,0" Foreground="#BDC3C7" IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Само поле ввода -->
                    <TextBox x:Name="SearchBox" Grid.Column="1" 
                 BorderThickness="0" Background="Transparent" 
                 VerticalContentAlignment="Center" FontSize="13"
                 TextChanged="SearchBox_TextChanged" Padding="5,0"/>
                </Grid>
            </Border>

        </Grid>

        <!-- РЯД 2: ТАБЛИЦА КЛИЕНТОВ (В КАРТОЧКЕ) -->
        <Border Grid.Row="2" Background="White" CornerRadius="10" BorderBrush="#DCDDE1" BorderThickness="1" Padding="5">
            
            <DataGrid x:Name="ClientsGrid" MouseDoubleClick="ClientsGrid_MouseDoubleClick"
                      AutoGenerateColumns="False" SelectionChanged="ClientsGrid_SelectionChanged" HeadersVisibility="Column"
                      CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F2F6" 
                      RowHeight="30" BorderThickness="0" Background="Transparent">
                <DataGrid.Resources>
                    <!-- Стиль, который центрирует текст во всех колонках по вертикали -->
                    <Style TargetType="DataGridCell">
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Background="{TemplateBinding Background}" BorderThickness="0">
                                        <ContentPresenter VerticalAlignment="Center" Margin="5,0"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="№" Binding="{Binding Id}" Width="40"/>
                    <DataGridTextColumn Header="ФИО Клиента" Binding="{Binding Name}" Width="*" FontWeight="SemiBold"/>
                    <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="180"/>
                    <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- РЯД 3: ИСТОРИЯ РЕМОНТОВ -->
        <StackPanel Grid.Row="3" Margin="0,25,0,0">
            <TextBlock Text="ПОСЛЕДНИЕ ЗАКАЗЫ КЛИЕНТА" FontSize="12" FontWeight="Bold" Foreground="#95A5A6" Margin="5,0,0,10"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Все заказы (общий список)" FontSize="11" Foreground="#95A5A6" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <CheckBox x:Name="ShowAllOrdersToggle" Click="ShowAllOrdersToggle_Click" Style="{StaticResource {x:Type CheckBox}}"/>
            </StackPanel>
            <Border Background="White" CornerRadius="10" BorderBrush="#DCDDE1" BorderThickness="1" Padding="5">
                <DataGrid x:Name="RepairsHistoryGrid" Height="300" MouseDoubleClick="RepairsHistoryGrid_MouseDoubleClick"
                          VirtualizingStackPanel.IsVirtualizing="True" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                          IsReadOnly="True" SelectionMode="Single" SelectionUnit="FullRow"
                          GridLinesVisibility="Horizontal" RowHeight="30" HorizontalGridLinesBrush="#F1F2F6" HeadersVisibility="Column" Background="Transparent" BorderThickness="0">
                    <DataGrid.Resources>
                        <!-- Стиль, который центрирует текст во всех колонках по вертикали -->
                        <Style TargetType="DataGridCell">
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Background="{TemplateBinding Background}" BorderThickness="0">
                                            <ContentPresenter VerticalAlignment="Center" Margin="5,0"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Принят" Binding="{Binding DateCreated, StringFormat={}{0:dd.MM.yyyy}}" Width="100"/>
                        <DataGridTextColumn Header="Велосипед" Binding="{Binding BikeInfo}" Width="180"/>
                        <DataGridTextColumn Header="Описание" Binding="{Binding ProblemDescription}" Width="*"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="120">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <!-- Закрашиваем фон всей ячейки -->
                                    <Setter Property="Background" Value="{Binding Status, Converter={StaticResource StatusColorConverter}}"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Foreground" Value="Black"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Итого" Binding="{Binding TotalCost, StringFormat={}{0:N2} р.}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="Margin" Value="0,0,10,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </StackPanel>

        <!-- РЯД 4: КНОПКИ УПРАВЛЕНИЯ -->
        <Grid Grid.Row="4" Margin="0,20,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Name="BtnAddPrimary" Content="➕ НОВЫЙ КЛИЕНТ" Click="AddClient_Click" 
                        Style="{StaticResource ActionButtonStyle}" Background="#27AE60" Margin="0,0,12,0"/>
                <Button x:Name="BtnAddSecondary" Content="🛠 ДОБАВИТЬ ЗАКАЗ" Click="AddRepair_Click" 
                        Style="{StaticResource ActionButtonStyle}" Background="#2980B9"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="📄 АКТ ПРИЕМКИ" Click="EntryAct_Click" 
                        Style="{StaticResource ActionButtonStyle}" Background="#34495E" Margin="0,0,12,0"/>
                <Button Content="💰 АКТ ВЫДАЧИ" Click="FinalAct_Click" 
                        Style="{StaticResource ActionButtonStyle}" Background="#34495E"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
