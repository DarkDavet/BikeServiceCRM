<Page x:Class="BusinessAccountantService.ClientsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BusinessAccountantService.Managers" 
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ClientsPage">
    <Page.Resources>
        <local:StatusColorConverter x:Key="StatusColorConverter"/>
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock x:Name="MainTitleText" Text="Список клиентов" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>

            <Label Content="Поиск:" Margin="30,0,5,0" VerticalAlignment="Center" Foreground="Gray"/>
            <TextBox x:Name="SearchBox" Width="250" Height="28" VerticalContentAlignment="Center" TextChanged="SearchBox_TextChanged" />

            <TextBlock x:Name="StatusInfoText" Text="Клиентов: 0 | Заказов: 0" Foreground="#27AE60" FontWeight="Bold" VerticalAlignment="Center" Margin="20,0,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <DataGrid x:Name="ClientsGrid" Visibility="Visible" 
      MouseDoubleClick="ClientsGrid_MouseDoubleClick"
      AutoGenerateColumns="False" SelectionChanged="ClientsGrid_SelectionChanged" 
      CanUserAddRows="False" CanUserDeleteRows="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40"/>
                    <DataGridTextColumn Header="ФИО Клиента" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="150"/>
                    <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- 2: НИЖНЯЯ ПАНЕЛЬ (История ремонтов)-->
        <StackPanel x:Name="RepairsPanel" Grid.Row="2" Visibility="Visible">
            <GridSplitter Height="5" HorizontalAlignment="Stretch" Background="#DDDDDD" Margin="0,10"/>

            <TextBlock Text="История ремонтов выбранного клиента:" FontWeight="Bold" Margin="0,0,0,5"/>
            <DataGrid x:Name="RepairsHistoryGrid" Height="180"
      MouseDoubleClick="RepairsHistoryGrid_MouseDoubleClick"
      CellEditEnding="RepairsHistoryGrid_CellEditEnding"
      AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                      IsReadOnly="True">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Статус: Принят" Click="ChangeStatus_Click" Tag="Принят"/>
                        <MenuItem Header="Статус: В работе" Click="ChangeStatus_Click" Tag="В работе"/>
                        <MenuItem Header="Статус: Готов" Click="ChangeStatus_Click" Tag="Готов"/>
                        <Separator/>
                        <MenuItem Header="Статус: Выдан" Click="ChangeStatus_Click" Tag="Выдан" Foreground="DarkGreen" FontWeight="Bold"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Велосипед" Binding="{Binding BikeInfo}" Width="150"/>
                    <DataGridTextColumn Header="Описание" Binding="{Binding ProblemDescription}" Width="*"/>
                    <DataGridComboBoxColumn Header="Статус" Width="120"
            SelectedItemBinding="{Binding Status, UpdateSourceTrigger=PropertyChanged}">

                        <DataGridComboBoxColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Background" Value="{Binding Status, Converter={StaticResource StatusColorConverter}}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{Binding Status, Converter={StaticResource StatusColorConverter}}"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridComboBoxColumn.CellStyle>

                        <DataGridComboBoxColumn.ElementStyle>
                            <Style TargetType="ComboBox">
                                <Setter Property="ItemsSource">
                                    <Setter.Value>
                                        <x:Array Type="sys:String" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                            <sys:String>Принят</sys:String>
                                            <sys:String>В работе</sys:String>
                                            <sys:String>Готов</sys:String>
                                            <sys:String>Выдан</sys:String>
                                        </x:Array>
                                    </Setter.Value>
                                </Setter>
                                <!-- Делаем комбобокс прозрачным, чтобы видеть цвет ячейки под ним -->
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGridComboBoxColumn.ElementStyle>

                        <DataGridComboBoxColumn.EditingElementStyle>
                            <Style TargetType="ComboBox">
                                <Setter Property="ItemsSource">
                                    <Setter.Value>
                                        <x:Array Type="sys:String" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                            <sys:String>Принят</sys:String>
                                            <sys:String>В работе</sys:String>
                                            <sys:String>Готов</sys:String>
                                            <sys:String>Выдан</sys:String>
                                        </x:Array>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGridComboBoxColumn.EditingElementStyle>
                    </DataGridComboBoxColumn>
                    <DataGridTextColumn Header="Оплата" Binding="{Binding TotalCost}" Width="80"/>
                    <DataGridTextColumn Header="Дата" Binding="{Binding DateFormatted}" Width="110"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>

        <!-- 3: КНОПКИ (Универсальные) -->
        <Grid Grid.Row="3" Margin="0,15,0,0">
            <!-- Левые кнопки -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Name="BtnAddPrimary" Content="Добавить клиента" Click="AddClient_Click" Width="130" Height="30" Margin="0,0,10,0"/>
                <Button x:Name="BtnAddSecondary" Content="Новый заказ" Click="AddRepair_Click" Width="130" Height="30"/>
            </StackPanel>

            <!-- Правые кнопки (PDF) -->
            <StackPanel x:Name="PdfButtonsPanel" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Акт приемки (PDF)" Click="EntryAct_Click" Width="140" Height="30" Margin="0,0,10,0" Background="#27AE60" Foreground="White" BorderThickness="0"/>
                <Button Content="Акт выдачи (PDF)" Click="FinalAct_Click" Width="140" Height="30" Background="#27AE60" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
