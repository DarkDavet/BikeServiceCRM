<Window x:Class="BusinessAccountantService.AddRepairWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BusinessAccountantService"
        mc:Ignorable="d"
        Title="Оформление ремонта" Height="400" Width="450" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="НОВЫЙ ЗАКАЗ" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

            <TextBlock Text="Марка и модель велосипеда:"/>
            <TextBox x:Name="BikeInfoBox" Margin="0,5,0,15" Height="25" Text="Например: Giant Talon 2023"/>

            <TextBlock Text="Описание проблемы:"/>
            <TextBox x:Name="ProblemBox" Margin="0,5,0,15" Height="80" TextWrapping="Wrap" AcceptsReturn="True"/>

            <TextBlock Text="Предварительная стоимость:"/>
            <TextBox x:Name="CostBox" Margin="0,5,0,15" Height="25" Text="0"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Принять в работу" Click="SaveRepair_Click" Width="130" Height="35" Background="#2980B9" Foreground="White"/>
                <Button Content="Отмена" Click="Cancel_Click" Width="80" Margin="10,0,0,0"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
