<Window x:Class="BusinessAccountantService.AddRepairWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BusinessAccountantService"
        mc:Ignorable="d"
        Title="Приемка велосипеда" Height="500" Width="450" WindowStartupLocation="CenterOwner" Background="#F5F6FA">
    <Grid Margin="20">
        <StackPanel>
            <!-- ШАПКА С ИНФО О КЛИЕНТЕ -->
            <Border Background="#EBFAFF" CornerRadius="8" Padding="15" Margin="0,0,0,20" BorderBrush="#BEE5F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="НОВЫЙ ЗАКАЗ" FontSize="14" FontWeight="Bold" Foreground="#2980B9" Margin="0,0,0,5"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Клиент: " Foreground="Gray" FontSize="14"/>
                        <TextBlock x:Name="ClientNameText" Grid.Column="1" Text="Иванов Иван Иванович" FontSize="14" FontWeight="Bold" Foreground="#2C3E50"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Label Content="Информация о велосипеде (Марка, модель, цвет):" FontWeight="SemiBold"/>
            <TextBox x:Name="BikeInfoBox" Height="32" VerticalContentAlignment="Center" Margin="0,0,0,15" Padding="5"/>

            <Label Content="Описание проблемы (жалобы клиента):" FontWeight="SemiBold"/>
            <TextBox x:Name="ProblemBox" Height="100" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,25" Padding="5"/>

            <Button Content="ОФОРМИТЬ ЗАКАЗ" Click="Save_Click" 
                    Height="45" Background="#27AE60" Foreground="White" FontWeight="Bold" BorderThickness="0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="Отмена" Click="Cancel_Click" Width="100" Height="30" Margin="0,15,0,0" Background="Transparent" Foreground="Gray" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>