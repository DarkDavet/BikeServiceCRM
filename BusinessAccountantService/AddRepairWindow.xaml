<Window x:Class="BusinessAccountantService.AddRepairWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BusinessAccountantService"
        mc:Ignorable="d"
        Title="Оформление заказа на ремонт — BikeLab" Height="550" Width="480" 
        WindowStartupLocation="CenterOwner" Background="#F5F6FA"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- 1. ГЛАВНАЯ КНОПКА (Оформить) -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="10"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 2. ВТОРОСТЕПЕННАЯ КНОПКА (Отмена) -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="Background" Value="#E0E2E6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D1D4D9"/>
                    <Setter Property="Foreground" Value="#2C3E50"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 3. СТИЛЬ ПОЛЕЙ ВВОДА -->
        <Style TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="BorderBrush" Value="#DCDDE1"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="White"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#3498DB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Инфо о клиенте -->
            <RowDefinition Height="*"/>
            <!-- Поля ввода -->
            <RowDefinition Height="Auto"/>
            <!-- Кнопки -->
        </Grid.RowDefinitions>

        <!-- БЛОК 1: ИНФО О КЛИЕНТЕ (Верхняя карточка) -->
        <Border Grid.Row="0" Background="White" CornerRadius="10" BorderBrush="#3498DB" BorderThickness="4,1,1,1" Padding="15" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="1" Opacity="0.05"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="НОВЫЙ ЗАКАЗ НА РЕМОНТ ДЛЯ:" FontSize="9" FontWeight="Bold" Foreground="#95A5A6" Margin="0,0,0,5"/>
                <TextBlock x:Name="ClientNameText" Text="Иванов Иван Иванович" FontSize="18" FontWeight="Black" Foreground="#2C3E50" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- БЛОК 2: ПОЛЯ ВВОДА -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="ИНФОРМАЦИЯ О ВЕЛОСИПЕДЕ" FontSize="10" FontWeight="Bold" Foreground="#95A5A6" Margin="2,0,0,5"/>
            <TextBox x:Name="BikeInfoBox" Height="42" VerticalContentAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="ОПИСАНИЕ ПРОБЛЕМЫ И ЖАЛОБЫ" FontSize="10" FontWeight="Bold" Foreground="#95A5A6" Margin="2,0,0,5"/>
            <TextBox x:Name="ProblemBox" Height="140" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
        </StackPanel>

        <!-- БЛОК 3: КНОПКИ -->
        <StackPanel Grid.Row="2" Margin="0,15,0,0">
            <Button Content="ОФОРМИТЬ ЗАКАЗ" Style="{StaticResource PrimaryButtonStyle}" 
                    Background="#27AE60" Click="Save_Click" Cursor="Hand"/>

            <Button Content="ОТМЕНА" Style="{StaticResource SecondaryButtonStyle}" 
                    Click="Cancel_Click" Margin="0,12,0,0" Cursor="Hand" HorizontalAlignment="Center" Width="120"/>
        </StackPanel>
    </Grid>
</Window>