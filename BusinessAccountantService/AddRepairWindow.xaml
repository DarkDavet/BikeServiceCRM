<Window x:Class="BusinessAccountantService.AddRepairWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BusinessAccountantService"
        mc:Ignorable="d"
        Title="Оформление ремонта" Height="600" Width="500" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="ОФОРМЛЕНИЕ НОВОГО ЗАКАЗА" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" Foreground="#2C3E50"/>

            <Label Content="Марка и модель велосипеда:"/>
            <TextBox x:Name="BikeInfoBox" Margin="0,0,0,10" Height="28" VerticalContentAlignment="Center" Foreground="Gray" GotFocus="TextBox_GotFocus"/>

            <Label Content="Описание проблемы:"/>
            <TextBox x:Name="ProblemBox" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10"/>

            <!-- Блок быстрого добавления (калькулятор) -->
            <GroupBox Header="Предварительный расчет запчастей/работ" Margin="0,0,0,10">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ItemNameBox" Grid.Column="0" Margin="0,0,5,0" Height="25" VerticalContentAlignment="Center"/>
                    <TextBox x:Name="ItemPriceBox" Grid.Column="1" Margin="0,0,5,0" Height="25" VerticalContentAlignment="Center"/>
                    <Button Content="+" Grid.Column="2" Width="30" Click="AddItem_Click" Background="#3498DB" Foreground="White" FontWeight="Bold"/>
                </Grid>
            </GroupBox>

            <Label Content="Заметки / Предварительный список работ:"/>
            <TextBox x:Name="WorksBox" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10"/>

            <!-- Финансовый блок -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <Label Content="Расходы (запчасти):" Foreground="#C0392B" FontWeight="Bold"/>
                    <TextBox x:Name="PartsCostBox" Text="0" Height="28" VerticalContentAlignment="Center" TextChanged="CostFields_TextChanged"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                    <Label Content="Итого к оплате:" Foreground="#27AE60" FontWeight="Bold"/>
                    <TextBox x:Name="CostBox" Text="0" Height="28" VerticalContentAlignment="Center" TextChanged="CostFields_TextChanged"/>
                </StackPanel>
            </Grid>

            <TextBlock x:Name="ProfitText" Text="Предварительная прибыль: 0 руб." 
                   HorizontalAlignment="Right" FontSize="13" FontWeight="Bold" Foreground="#2980B9" Margin="0,0,0,15"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Принять в работу" Click="SaveRepair_Click" Width="140" Height="35" Background="#27AE60" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                <Button Content="Отмена" Click="Cancel_Click" Width="90" Height="35" Margin="10,0,0,0" BorderThickness="1"/>
            </StackPanel>
        </StackPanel>
    </Grid>

</Window>
