<Window x:Class="BusinessAccountantService.AddPartToRepairRecordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BusinessAccountantService"
        mc:Ignorable="d"
        Title="Выбор запчасти — BikeLab" Height="400" Width="420" 
        WindowStartupLocation="CenterOwner" Background="#F5F6FA"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- 1. ОСНОВНАЯ КНОПКА (Добавить) -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 2. ВТОРОСТЕПЕННАЯ КНОПКА (Отмена) -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="Background" Value="#E0E2E6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D1D4D9"/>
                    <Setter Property="Foreground" Value="#2C3E50"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 3. СТИЛЬ ПОЛЕЙ ВВОДА -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#DCDDE1"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#3498DB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Шапка -->
            <RowDefinition Height="*"/>
            <!-- Выбор -->
            <RowDefinition Height="Auto"/>
            <!-- Кнопки -->
        </Grid.RowDefinitions>

        <!-- ШАПКА -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="ДОБАВИТЬ ЗАПЧАСТЬ" FontSize="20" FontWeight="Black" Foreground="#2C3E50"/>
            <Separator Height="2" Background="#3498DB" Width="40" HorizontalAlignment="Left" Margin="2,5,0,0"/>
        </StackPanel>

        <!-- ПОИСК И ОСТАТОК -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="ПОИСК ДЕТАЛИ НА СКЛАДЕ" FontSize="9" FontWeight="Bold" Foreground="#95A5A6" Margin="2,0,0,0"/>
            <ComboBox x:Name="PartSearchBox" IsEditable="True" 
                      TextSearch.TextPath="Name"
                      DisplayMemberPath="Name" IsTextSearchEnabled="False"
                      KeyUp="PartSearchBox_KeyUp" 
                      SelectionChanged="PartSearchBox_SelectionChanged" />

            <!-- Инфо-карточка остатка (с тенью) -->
            <Border Background="White" CornerRadius="10" BorderBrush="#DCDDE1" BorderThickness="1" Padding="15" Margin="0,20,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="1" Opacity="0.05"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="В НАЛИЧИИ" FontSize="9" FontWeight="Bold" Foreground="#95A5A6"/>
                        <TextBlock x:Name="StockText" Text="0 шт." FontSize="22" FontWeight="Black" Foreground="#2C3E50" Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="КОЛ-ВО ДЛЯ ЗАКАЗА" FontSize="9" FontWeight="Bold" Foreground="#3498DB"/>
                        <TextBox x:Name="QtyBox" Text="1" FontSize="18" FontWeight="Black" Margin="0,5,0,0" HorizontalContentAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>

        <!-- КНОПКИ -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="ОТМЕНА" 
                    Style="{StaticResource SecondaryButtonStyle}" 
                    Click="Cancel_Click" 
                    Width="100" Margin="0,0,10,0"/>

            <Button Content="ДОБАВИТЬ" 
                    Style="{StaticResource PrimaryButtonStyle}" 
                    Background="#3498DB" 
                    Click="Add_Click" Width="140"/>
        </StackPanel>
    </Grid>
</Window>