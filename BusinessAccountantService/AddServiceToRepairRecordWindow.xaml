<Window x:Class="BusinessAccountantService.AddServiceToRepairRecordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BusinessAccountantService"
        mc:Ignorable="d"
        Title="Выбор операции — BikeLab" Height="400" Width="420" 
        WindowStartupLocation="CenterOwner" Background="#F5F6FA"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- 1. ГЛАВНАЯ КНОПКА (Добавить) -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 2. ВТОРОСТЕПЕННАЯ КНОПКА (Отмена) -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="Background" Value="#E0E2E6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D1D4D9"/>
                    <Setter Property="Foreground" Value="#2C3E50"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 3. СТИЛЬ ПОЛЕЙ ВВОДА -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#DCDDE1"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="White"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#27AE60"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Шапка -->
            <RowDefinition Height="*"/>
            <!-- Поля -->
            <RowDefinition Height="Auto"/>
            <!-- Кнопки -->
        </Grid.RowDefinitions>

        <!-- ШАПКА -->
        <StackPanel Grid.Row="0" Margin="0,0,0,25">
            <TextBlock Text="ДОБАВИТЬ РАБОТУ" FontSize="20" FontWeight="Black" Foreground="#2C3E50"/>
            <Separator Height="2" Background="#27AE60" Width="40" HorizontalAlignment="Left" Margin="2,5,0,0"/>
        </StackPanel>

        <!-- ПОЛЯ ВВОДА -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="НАИМЕНОВАНИЕ РАБОТ" FontSize="9" FontWeight="Bold" Foreground="#95A5A6" Margin="2,0,0,5"/>
            <ComboBox x:Name="ServiceSearchBox" IsEditable="True" Height="40"
                      DisplayMemberPath="Name" IsTextSearchEnabled="False"
                      KeyUp="ServiceSearchBox_KeyUp" 
                      SelectionChanged="ServiceSearchBox_SelectionChanged"
                      VerticalContentAlignment="Center" Margin="0,0,0,20"/>

            <!-- КАРТОЧКА СТОИМОСТИ -->
            <Border Background="White" CornerRadius="10" BorderBrush="#DCDDE1" BorderThickness="1" Padding="15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="1" Opacity="0.05"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="СТОИМОСТЬ РАБОТ (BYN)" FontSize="9" FontWeight="Bold" Foreground="#27AE60" Margin="2,0,0,5"/>
                    <TextBox x:Name="PriceBox" FontSize="24" FontWeight="Black" Foreground="#27AE60" 
                             BorderThickness="0" Background="Transparent" Padding="0" Height="Auto"/>
                    <Separator Height="1" Background="#F1F2F6" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- КНОПКИ -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Content="ДОБАВИТЬ В ЗАКАЗ" Style="{StaticResource PrimaryButtonStyle}" 
                    Background="#27AE60" Click="Add_Click" Cursor="Hand"/>

            <Button Content="ОТМЕНА" Grid.Column="1" 
                    Style="{StaticResource SecondaryButtonStyle}" 
                    Click="Cancel_Click" 
                    Width="100" Margin="15,0,0,0" Cursor="Hand"/>
        </Grid>
    </Grid>
</Window>