<Window x:Class="BusinessAccountantService.AddServiceToRepairRecordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BusinessAccountantService"
        mc:Ignorable="d"
        Title="Добавить работу" Height="320" Width="400" WindowStartupLocation="CenterOwner" Background="#F5F6FA">
    <Grid Margin="25">
        <StackPanel>
            <TextBlock Text="НОВАЯ ОПЕРАЦИЯ" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" Foreground="#27AE60"/>

            <!-- Поиск по прайс-листу -->
            <Label Content="Наименование услуги (поиск или ввод):" FontSize="12" Foreground="#7F8C8D"/>
            <ComboBox x:Name="ServiceSearchBox" Height="32" IsEditable="True" 
                      DisplayMemberPath="Name" IsTextSearchEnabled="False"
                      KeyUp="ServiceSearchBox_KeyUp" 
                      SelectionChanged="ServiceSearchBox_SelectionChanged"
                      DropDownOpened="ServiceSearchBox_DropDownOpened" 
                      VerticalContentAlignment="Center" Margin="0,0,0,15"/>

            <!-- Цена -->
            <Label Content="Стоимость работы (₽):" FontSize="12" Foreground="#7F8C8D"/>
            <TextBox x:Name="PriceBox" Height="35" VerticalContentAlignment="Center" 
                     FontSize="18" FontWeight="Bold" Foreground="#27AE60" Margin="0,0,0,25"/>

            <!-- Кнопки -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Content="ДОБАВИТЬ В ЗАКАЗ" Grid.Column="0" Click="Add_Click" 
                        Height="40" Background="#27AE60" Foreground="White" FontWeight="Bold" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Content="Отмена" Grid.Column="1" Click="Cancel_Click" 
                        Width="80" Height="40" Margin="10,0,0,0" Background="#BDC3C7" BorderThickness="0"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>