<Window x:Class="BusinessAccountantService.RefillItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BusinessAccountantService"
        mc:Ignorable="d"
        Title="Пополнение склада" Height="350" Width="400" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock x:Name="ItemTitleText" Text="ПОПОЛНЕНИЕ" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" Foreground="#2C3E50"/>

            <Label Content="Количество (добавить к остатку):"/>
            <TextBox x:Name="RefillQuantityBox" Text="1" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

            <Border Background="#F9F9F9" CornerRadius="5" Padding="10" Margin="0,0,0,20" BorderBrush="#DCDDE1" BorderThickness="1">
                <StackPanel>
                    <!-- Видимость управляется из C# в зависимости от категории -->
                    <CheckBox x:Name="BulkModeCheck" Content="Закупка оптом (за всю партию)" 
                              Margin="0,0,0,10" Foreground="#2980B9" FontWeight="SemiBold"
                              Visibility="Collapsed"/>

                    <Grid>
                        <!-- ПОЛЕ 1: Цена за 1 шт (скрывается при опте) -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, ElementName=BulkModeCheck}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Label Content="Новая цена закупки (за 1 шт):" Foreground="#C0392B"/>
                            <TextBox x:Name="NewPurchasePriceBox" Height="30" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <!-- ПОЛЕ 2: Сумма за партию (появляется при опте) -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, ElementName=BulkModeCheck}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Label Content="Сумма за всю партию (BYN):" Foreground="#2980B9" FontWeight="Bold"/>
                            <TextBox x:Name="BulkTotalBox" Text="0" Height="30" VerticalContentAlignment="Center" Background="#EBF5FB"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <UniformGrid Columns="2">
                <Button Content="ПРИНЯТЬ" Click="SaveRefill_Click" Height="35" Background="#27AE60" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                <Button Content="Отмена" Click="Cancel_Click" Height="35" Margin="10,0,0,0"/>
            </UniformGrid>
        </StackPanel>
    </Grid>
</Window>
