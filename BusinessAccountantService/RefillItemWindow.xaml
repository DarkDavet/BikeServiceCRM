<Window x:Class="BusinessAccountantService.RefillItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BusinessAccountantService"
        mc:Ignorable="d"
        Title="RefillItemWindow" Height="300" Width="400">
    <Grid>
        <StackPanel Margin="20">
            <TextBlock x:Name="ItemTitleText" Text="Пополнение: [Название]" FontWeight="Bold" Margin="0,0,0,15"/>

            <Label Content="Количество (штук):"/>
            <TextBox x:Name="RefillQtyBox" Text="1" Margin="0,0,0,10" Height="28"/>

            <Label Content="Новая цена закупки (за ед.):" Foreground="#C0392B" FontWeight="Bold"/>
            <TextBox x:Name="NewPurchasePriceBox" Margin="0,0,0,20" Height="28"/>

            <Button Content="Принять на склад" Click="SaveRefill_Click" Background="#27AE60" Foreground="White" Height="35"/>
        </StackPanel>

    </Grid>
</Window>
